# Gruyere Environment Configuration
# Copy this file to .env and adjust the values as needed

# ===========================
# Server Configuration
# ===========================

# Port the application will listen on
# Default: 3141
PORT=3141

# Host binding (0.0.0.0 allows external connections, 127.0.0.1 is local only)
# Default: 0.0.0.0
HOST=0.0.0.0

# Origin URL for CORS and security headers
# IMPORTANT: Set this to your actual domain in production
# Examples:
#   - http://localhost:3141 (development)
#   - http://192.168.1.100:3141 (local network)
#   - https://gruyere.example.com (production with reverse proxy)
ORIGIN=http://localhost:3141

# ===========================
# Application Environment
# ===========================

# Node environment (production or development)
# Default: production
NODE_ENV=production

# ===========================
# Logging Configuration
# ===========================

# Log level for Pino logger
# Options: fatal, error, warn, info, debug, trace
# Default: info
LOG_LEVEL=info

# ===========================
# Configuration Directory
# ===========================

# Path to configuration files
# Default: ./config (development) or /app/config (Docker)
# CONFIG_DIR=/app/config
